---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

// Sort by order ascending, then featured, then title
const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.title.localeCompare(b.data.title);
});

// Show first 4 projects initially; the rest are hidden inside an expandable panel
const visibleProjects = sortedProjects.slice(0, 4);
const hiddenProjects = sortedProjects.slice(4);
---

<BaseLayout title="Projects | Khushal Pareta">
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    
    <header class="mb-12">
      <h1 class="text-4xl md:text-5xl font-mono font-bold mb-4">
        <span class="text-primary">[</span>Projects<span class="text-primary">]</span>
      </h1>
      <p class="text-muted-foreground max-w-2xl">
        A collection of data engineering, machine learning, and cloud infrastructure projects I've built.
      </p>
    </header>

    <!-- Original grid (commented out – kept for reference) -->
    {sortedProjects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedProjects.map(project => (
          <ProjectCard project={project} />
        ))}
      </div>
    ) : (
      <div class="glass-card p-12 text-center">
        <p class="text-muted-foreground">No projects available yet. Check back soon!</p>
      </div>
    )}

    {/* 
      New grid with expandable hidden projects
      - Show first 4 projects initially
      - If there are more than 4, show a "Show all projects" button that expands to reveal the rest
     
    {sortedProjects.length > 0 ? (
      <>
        <!-- Visible projects (first 4) -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {visibleProjects.map(project => (
            <ProjectCard project={project} />
          ))}
        </div>

        <!-- Hidden projects (expandable) -->
        {hiddenProjects.length > 0 && (
          <details class="group mt-8">
            <summary class="glass-card p-4 cursor-pointer font-mono text-foreground hover:text-primary transition-colors list-none flex items-center justify-center gap-2">
              <span>Show all projects ({hiddenProjects.length} more)</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </summary>
