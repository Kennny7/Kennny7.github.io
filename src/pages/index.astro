---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactButtons from '@components/ContactButtons.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { SKILLS, IMPACT_STATS, EDUCATION } from '@utils/constants';
import { getCollection } from 'astro:content';

const featuredProjects = await getCollection('projects', ({ data }) => data.featured === true);

// Experience section: fetch and render all featured entries
const experienceEntries = (await getCollection('experience', ({ data }) => data.featured === true))
  .sort((a, b) => a.data.order - b.data.order);

const renderedExperiences = await Promise.all(
  experienceEntries.map(async (entry) => {
    const { Content } = await entry.render();
    return { ...entry, Content };
  })
);
---

<BaseLayout>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    
    <!-- Hero Section -->
    <section class="mb-20">
      <div class="flex flex-col items-center text-center">
        <h1 class="text-4xl md:text-6xl font-mono font-bold mb-4">
          <span class="text-primary">[</span>Khushal Pareta<span class="text-primary">]</span>
        </h1>
        <p class="text-xl md:text-2xl text-gradient font-mono mb-4">
          MLOps Engineer
        </p>
        <p class="text-muted-foreground max-w-2xl mb-8">
          Bridging data engineering, machine learning, and cloud infrastructure to build production‑ready, scalable AI systems.
        </p>
        <ContactButtons variant="default" />
      </div>
    </section>

    <!-- Resume Download Button -->
    <section class="mb-20">
      <div class="flex justify-center">
        <a
          href="/data/resume.pdf"
          download
          class="glass-card px-8 py-4 inline-flex items-center gap-3 font-mono text-lg text-primary hover:text-primary/80 hover:border-primary/30 transition-all"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Download Resume
        </a>
      </div>
    </section>

    <!-- (Commented out) Impact Stats - preserve for later use -->
    
    <section class="mb-20">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {IMPACT_STATS.map(stat => (
          <div class="glass-card p-6 text-center">
            <div class="text-3xl md:text-4xl font-mono font-bold text-primary mb-2">
              {stat.value}
            </div>
            <div class="text-sm text-muted-foreground">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </section>
   

    <!-- Skills Section -->
    <section class="mb-20">
      <h2 class="section-title">Core Competencies</h2>
      <div class="glass-card overflow-hidden">
        <div class="divide-y divide-border/30">
          {SKILLS.map((domain, index) => (
            <details class="group" open={index === 0}>
              <summary class="p-4 cursor-pointer font-mono text-foreground hover:text-primary transition-colors list-none flex items-center justify-between">
                <span>{domain.domain}</span>
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              </summary>
              <div class="px-4 pb-4">
                <div class="flex flex-wrap gap-2">
                  {domain.skills.map(skill => (
                    <span class="skill-badge">{skill}</span>
                  ))}
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="mb-20">
      <h2 class="section-title">Experience</h2>
      <div class="glass-card overflow-hidden">
        <div class="divide-y divide-border/30">
          {renderedExperiences.map((exp, index) => (
            <details class="group" open={index === 0}>
              <summary class="p-4 cursor-pointer font-mono text-foreground hover:text-primary transition-colors list-none flex items-center justify-between">
                <span>
                  {exp.data.title} @ {exp.data.company}
                  <span class="text-sm text-muted-foreground ml-4">
                    {exp.data.startDate} – {exp.data.endDate || 'Present'}
                  </span>
                </span>
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6"/>
                </svg>
              </summary>
              <div class="px-6 pb-6">
                <!-- Improved content styling for readability -->
                <div class="text-muted-foreground leading-relaxed space-y-2 
                            [&>ul]:list-disc [&>ul]:list-inside [&>ul]:space-y-1 
                            [&>ol]:list-decimal [&>ol]:list-inside [&>ol]:space-y-1
                            [&>p]:mb-2">
                  <exp.Content />
                </div>
                {exp.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-4">
                    {exp.data.tags.map(tag => (
                      <span class="skill-badge">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </details>
          ))}
          {renderedExperiences.length === 0 && (
            <p class="p-4 text-center text-muted-foreground">No experience entries yet.</p>
          )}
        </div>
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="mb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-title !mb-0">Featured Projects</h2>
        <a href="/projects" class="font-mono text-sm text-primary hover:text-primary/80">
          [View All]
        </a>
      </div>
      
      {featuredProjects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featuredProjects.map(project => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <p class="text-muted-foreground text-center py-12">No featured projects yet.</p>
      )}
    </section>

    <!-- Education -->
    <section>
      <h2 class="section-title">Education</h2>
      <div class="glass-card divide-y divide-border/30">
        {EDUCATION.map(edu => (
          <div class="p-6">
            <div class="flex flex-wrap items-baseline justify-between gap-4 mb-2">
              <h3 class="text-lg font-mono font-semibold">{edu.degree}</h3>
              <span class="text-sm text-primary font-mono">{edu.year}</span>
            </div>

            <p class="text-muted-foreground">
              {edu.institution}
              {edu.score && <> • {edu.score}</>}
            </p>

            {edu.highlight && (
              <p class="text-sm text-primary mt-2">[+] {edu.highlight}</p>
            )}
          </div>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>