---
export interface Props {
  title: string;
  company: string;
  startDate: string;
  endDate?: string;
  tags: string[];
  logo?: string;
  summary?: string;
  Content: any; 
}

const {
  title,
  company,
  startDate,
  endDate = 'Present',
  tags,
  logo,
  summary,
  Content,
} = Astro.props;
---

<div class="relative pl-8 pb-10 group/timeline last:pb-0">
  <!-- Timeline line & dot -->
  <div class="absolute left-0 top-0 w-0.5 h-full bg-border/30 group-last/timeline:hidden"></div>
  <div class="absolute left-[-5px] top-1.5 w-3 h-3 rounded-full bg-primary border-2 border-background"></div>

  <!-- Card -->
  <div class="glass-card p-6 hover:border-primary/30 transition-all">
    <!-- Header: logo + title/company -->
    <div class="flex items-start gap-4 mb-3">
      {logo ? (
        <img src={logo} alt={`${company} logo`} class="w-10 h-10 rounded-md object-contain bg-white/10 p-0.5" />
      ) : (
        <div class="w-10 h-10 rounded-md bg-primary/10 flex items-center justify-center text-primary font-mono font-bold text-sm">
          {company.charAt(0)}
        </div>
      )}
      <div>
        <h3 class="text-lg font-mono font-semibold text-foreground">{title}</h3>
        <p class="text-primary font-mono text-sm">{company}</p>
        <p class="text-xs text-muted-foreground mt-1 font-mono">
          {startDate} – {endDate}
        </p>
      </div>
    </div>

    <!-- Summary / Teaser (always visible) -->
    {summary && (
      <p class="text-muted-foreground text-sm mb-3 leading-relaxed">{summary}</p>
    )}

    <!-- Hidden full content -->
    <div class="exp-detail hidden mt-3">
      <div class="text-muted-foreground leading-relaxed
                  [&>ul]:list-none [&>ul]:space-y-1.5
                  [&>ul>li]:relative [&>ul>li]:pl-5
                  [&>ul>li]:before:content-['–'] [&>ul>li]:before:absolute [&>ul>li]:before:left-0 [&>ul>li]:before:text-primary/60
                  [&>ol]:list-decimal [&>ol]:list-inside [&>ol]:space-y-1.5
                  [&>p]:mb-2
                  prose-a:text-primary">
        <Content />
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <span class="skill-badge">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Toggle button -->
    <button
      class="mt-2 text-sm font-mono text-primary hover:text-primary/80 transition-colors flex items-center gap-1"
      onclick="const detail = this.parentElement.querySelector('.exp-detail'); const isHidden = detail.classList.toggle('hidden'); this.querySelector('span').textContent = isHidden ? 'Show less' : 'Read more'; this.querySelector('svg').classList.toggle('rotate-180', !isHidden);"
    >
      <span>Read more</span>
      <svg class="w-3 h-3 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </button>
  </div>
</div>